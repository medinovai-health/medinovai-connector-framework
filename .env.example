# Copy to .env locally (never commit .env)
# Python / service
PORT=8000
SERVICE_NAME=medinovai-connector-framework
PYTHONPATH=src

# medinovai-registry (service discovery)
REGISTRY_URL=http://medinovai-registry.medinovai:8000

# medinovai-integration-gateway (downstream ingest / orchestration)
INTEGRATION_GATEWAY_URL=http://medinovai-integration-gateway:8000
MOS_INTEGRATION_GATEWAY_INGEST_PATH=/api/v1/ingest

# Secrets prefix for medinovai-secrets-manager-bridge lookups
MOS_SECRETS_PREFIX=medinovai/connector-framework

# Per-connector base URLs (non-secret; override per environment)
MOS_AWS_HEALTHLAKE_FHIR_ENDPOINT=https://healthlake.us-east-1.amazonaws.com/fhir/R4
MOS_DATAVANT_BASE_URL=https://api.datavant.example
MOS_TRINETX_BASE_URL=https://api.trinetx.example
MOS_N3C_ENCLAVE_URL=https://enclave.n3c.example
MOS_PCORNET_COORDINATING_CENTER_URL=https://pcornet.example
MOS_MAYO_MCP_BASE_URL=https://mcp.mayo.example
MOS_AZURE_HDS_FHIR_ENDPOINT=https://example.workspace.azurehealthcareapis.com/fhir
MOS_ALL_OF_US_WORKBENCH_URL=https://workbench.researchallofus.org

# Optional: multi-tenant ingest enforcement
MOS_REQUIRE_TENANT_ID=false

# Logging
MOS_LOG_LEVEL=INFO
